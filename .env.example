# ================================
# Credit Intelligence Platform
# Environment Variables Template
# Copy this file to .env and fill in your real keys
# Never commit .env to GitHub
# ================================

# OpenAI (for RAG + memo generation)
OPENAI_API_KEY=your_openai_api_key_here

# FRED API (macro rates)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# SEC EDGAR (no key needed but set your identity)
EDGAR_USER_AGENT=your_name your_email@gmail.com

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=credit_intelligence
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# App Settings
ENVIRONMENT=development
LOG_LEVEL=INFO